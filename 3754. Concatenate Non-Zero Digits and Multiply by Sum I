class Solution {
    public long sumAndMultiply(int n) {
        if (n == 0) return 0;

        long num = 0;
        long place = 1;
        long sum = 0;

        while (n > 0) {
            int digit = n % 10;
            if (digit != 0) {
                num += digit * place;
                place *= 10;
                sum += digit;
            }
            n /= 10;
        }

        return num * sum;
    }
}
